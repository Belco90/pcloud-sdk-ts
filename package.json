{
	"name": "pcloud-kit",
	"version": "0.1.2",
	"description": "Unofficial pCloud SDK",
	"keywords": [
		"esm",
		"pcloud",
		"sdk",
		"typescript"
	],
	"homepage": "https://github.com/Belco90/pcloud-kit#readme",
	"bugs": "https://github.com/Belco90/pcloud-kit/issues",
	"license": "MIT",
	"author": "Mario Beltrán (https://belco.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Belco90/pcloud-kit.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./oauth": {
			"types": "./dist/oauth.d.ts",
			"default": "./dist/oauth.js"
		},
		"./oauth-browser": {
			"types": "./dist/oauth-browser.d.ts",
			"default": "./dist/oauth-browser.js"
		},
		"./errors": {
			"types": "./dist/errors.d.ts",
			"default": "./dist/errors.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"prepare": "simple-git-hooks",
		"prepublishOnly": "pnpm type-check && pnpm test && pnpm build",
		"scenario:browser": "vite --config examples/browser/vite.config.ts",
		"scenario:browser:real": "VITE_PCLOUD_REAL=1 vite --config examples/browser/vite.config.ts",
		"scenario:node": "tsx examples/node/manual.ts",
		"scenario:node:real": "tsx examples/node/manual.ts --real",
		"test": "vitest run",
		"test:browser": "vitest run --project scenario-browser",
		"test:coverage": "vitest run --coverage",
		"test:scenario-node": "vitest run --project scenario-node",
		"test:unit": "vitest run --project unit",
		"test:watch": "vitest",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"msw": "^2.7.0",
		"nano-staged": "^1.0.2",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.0.0",
		"playwright": "^1.49.0",
		"publint": "^0.3.18",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"simple-git-hooks": "^2.13.1",
		"tsdown": "^0.21.10",
		"tsx": "^4.19.0",
		"typescript": "^5.8.0",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm exec nano-staged"
	},
	"nano-staged": {
		"*.{ts,js,mts,mjs}": [
			"oxfmt",
			"oxlint --fix"
		],
		"*.json": [
			"oxfmt"
		]
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"packageManager": "pnpm@10.33.0",
	"msw": {
		"workerDirectory": [
			"examples/browser/public"
		]
	}
}
