{
	"name": "pcloud-sdk",
	"version": "0.1.0",
	"description": "Unofficial pCloud SDK",
	"keywords": [
		"esm",
		"pcloud",
		"sdk",
		"typescript"
	],
	"license": "MIT",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./oauth": {
			"types": "./dist/oauth.d.ts",
			"default": "./dist/oauth.js"
		},
		"./oauth-browser": {
			"types": "./dist/oauth-browser.d.ts",
			"default": "./dist/oauth-browser.js"
		},
		"./errors": {
			"types": "./dist/errors.d.ts",
			"default": "./dist/errors.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"prepare": "simple-git-hooks",
		"prepublishOnly": "pnpm type-check && pnpm test && pnpm build",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"nano-staged": "^1.0.2",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.0.0",
		"publint": "^0.3.18",
		"simple-git-hooks": "^2.13.1",
		"tsdown": "^0.21.10",
		"typescript": "^5.8.0",
		"vitest": "^3.0.0"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm exec nano-staged"
	},
	"nano-staged": {
		"*.{ts,js,mts,mjs,json}": [
			"oxfmt",
			"oxlint --fix"
		]
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"packageManager": "pnpm@10.33.0"
}
